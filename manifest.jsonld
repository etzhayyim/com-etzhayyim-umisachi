{
  "@context": {
    "@vocab": "https://etzhayyim.com/ns/actor#",
    "id": "@id",
    "type": "@type"
  },
  "id": "actor:umisachi",
  "type": "Actor",
  "name": "umisachi",
  "glyph": "海幸",
  "purpose": "Seafood / marine-bounty (海産物) KG mirror — the marine sibling of mitsuho 瑞穂 and the handoff target of mitsuho N9 (ocean out-of-scope there). Weaves fish stocks / fisheries+aquaculture / cold-chain logistics / markets + the PRESSURES that gate sustainable provisioning into the kotoba Datom log; surfaces equitable-provisioning NOURISHMENT vs 取-depletion routed to RESTORATION. Factory-fishing is structurally unrepresentable.",
  "status": "R0-design-only",
  "tier": "B",
  "adr": "2606074200",
  "dependsOnAdr": ["2606073000", "2606073200", "2605261015", "2606013400", "2606041827", "2605081300", "2605301600", "2605312345", "2605215000", "2605241500"],
  "schema": ["00-contracts/schemas/umisachi-ontology.kotoba.edn"],
  "substrate": {
    "state": "kotoba Datom log (ADR-2605312345) — methods/datom_emit.clj emits canonical EAVT",
    "largeAssets": "DataLad → IPFS (80-data/umisachi) — NO git-lfs",
    "inference": "Murakumo-only (ADR-2605215000)",
    "runtime": "kotoba pywasm actor (componentize-py) — methods authored in Clojure (babashka), pure stdlib + clojure.edn"
  },
  "integrates": ["actor:mitsuho", "actor:inochi", "actor:watari", "actor:watatsuna", "actor:funadaiku", "actor:tsumugi", "actor:kabuto", "actor:okaimono"],
  "lineage": "marine sibling of mitsuho 瑞穂 (land/rice abundance) and of the KG-mirror lineage (inochi/asobi/tsumugi/danjo); the ocean half of food provisioning — closes the seafood/fisheries coverage gap mitsuho N9 reserved",
  "cells": [
    {
      "id": "cell:umisachi.analyze",
      "method": "methods/analyze.clj",
      "input": "data/seed-umisachi-graph.kotoba.edn",
      "output": ["out/nourishment-report.md"],
      "pipeline": "load-edn (+ G1/G4 charter guard) → edge-primary integral (Σ incident provisioning-load × disclosed access weight) → provisioning-nourishment + depletion-load + depletion-concentration, aggregate-first",
      "doc": "edge-primary nourishment/depletion; restoration map, never a catch-target list"
    },
    {
      "id": "cell:umisachi.datom-emit",
      "method": "methods/datom_emit.clj",
      "input": "data/seed-umisachi-graph.kotoba.edn",
      "output": ["out/umisachi-datoms.kotoba.edn"],
      "pipeline": "ground EAVT datoms [e a v tx :add] (durable) + derived readouts flagged :bond/is-transient (computed on read, N1/G2)",
      "doc": "kotoba Datom-log projection — first-class canonical state (ADR-2605312345)"
    },
    {
      "id": "cell:umisachi.coverage",
      "method": "methods/coverage_report.clj",
      "input": "data/seed-umisachi-graph.kotoba.edn",
      "output": ["out/coverage-report.md"],
      "pipeline": "stock-status + sustainable-method + logistics + market-access + pressure → gap map",
      "doc": "honest coverage (all-seafood ~0 by design); names thin/missing buckets per wave (G5)"
    }
  ],
  "gates": {
    "G1": "NOURISHMENT / RESTORATION map, NEVER a catch-target / fishing-ground list — coordinate-shaped keys (lat/lon/gps/geohash) refused at load; regions are coarse FAO-area NAMES only; no per-stock catch score; the 取-holder is the pressure, the bearer is the stock/habitat/market, the routing is restoration",
    "G2": "edge-primary (N1) — 取 lives only on :en/load; a node's depletion/nourishment is the integral computed on read; no stored score-of-stock",
    "G3": "non-adjudicating (N3) — :stock/status & :market/access are DISCLOSED facts (FAO/RAM/ICES/IUCN/CCAMLR/ICCAT/MSC), never umisachi verdicts",
    "G4": "factory-fishing / bottom-trawl / driftnet / IUU / dynamite / cyanide are UNREPRESENTABLE as a :fishery method (refused at load) — representable ONLY as a :pressure node (the disclosed harm), routed to restoration; inherits mitsuho N1/N9 (no ocean factory-fishing)",
    "G5": "sourcing honesty — every record :authoritative | :representative; coverage of all seafood ~0 by design (coverage_report names the gaps)",
    "G6": "Murakumo-only narration (ADR-2605215000)",
    "G7": "outward-gated — live ingest (FAO/RFMO catch statistics, MSC/ASC certs) requires Council + operator DID; R0 = analyzer + schema + seed only",
    "G8": "no person/vessel tracking — aggregate stock/fleet scale only (live vessel position is watari's aggregate lane); never 'where is vessel X'"
  }
}
